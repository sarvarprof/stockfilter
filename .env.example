# ─────────────────────────────────────────────────────────────────────
# Stock-screener environment variables
# Copy to .env and fill in real values. .env is git-ignored.
# ─────────────────────────────────────────────────────────────────────

# Flask session secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# FRED API key for valuator/macro.py — free key from https://fredaccount.stlouisfed.org/
# Without this, the app falls back to public-CSV (slower, occasionally throttled).
FRED_API_KEY=

# SEC EDGAR User-Agent — required by SEC. Format: "<app-name> <email>"
EDGAR_USER_AGENT=stockscreener you@example.com

# Optional — Anthropic key for Claude-backed news sentiment
# ANTHROPIC_API_KEY=

# Optional — override the persistent cache DB location
# Default: <repo-root>/cache/api_cache.db
# TRADING_CACHE_DB=/var/lib/stock-screener/api_cache.db

# Optional — override the EDGAR/macro disk-cache location
# Default: ~/.valuation_cache
# VALUATION_CACHE=/var/lib/stock-screener/valuation_cache
